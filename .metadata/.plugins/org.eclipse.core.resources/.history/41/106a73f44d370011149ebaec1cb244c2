#include "myGpioLib.h"
#include <stdio.h>

/* ---------- Etape 1 ---------- */
void LED2_Write(uint8_t state) {
    if (state)
        GPIOA_ODR = (GPIOA_ODR | LED2_BIT);
    else
        GPIOA_ODR = (GPIOA_ODR & ~LED2_BIT);
}

/* ---------- Etape 2 ---------- */
uint8_t LED2_Read(void) {
    return (GPIOA_ODR & LED2_BIT) ? 1 : 0;
}

/* ---------- Etape 3 ---------- */
uint8_t B1_Read(void) {
    /* B1 est actif à l'état bas (pull-up interne) */
    return (GPIOC_IDR & B1_BIT) ? 0 : 1;
}

/* ---------- Etape 4 : Tests unitaires ---------- */
void GPIO_Test(void) {
    uint8_t result;

    printf("\r\n=== TEST GPIO ===\r\n");

    /* -- Test LED2 allumée -- */
    LED2_Write(1);
    result = LED2_Read();
    printf("LED2 ON  -> Read = %d : %s\r\n", result, (result == 1) ? "OK" : "Echec");

    /* -- Test LED2 éteinte -- */
    LED2_Write(0);
    result = LED2_Read();
    printf("LED2 OFF -> Read = %d : %s\r\n", result, (result == 0) ? "OK" : "Echec");

    /* -- Test bouton B1 (manuel) -- */
    printf("Appuyez sur B1 USER dans les 5 secondes...\r\n");
    uint32_t timeout = 5000000;
    while (!B1_Read() && timeout--);
    result = B1_Read();
    printf("Bouton B1 -> Read = %d : %s\r\n", result, (result == 1) ? "OK" : "Echec");

    printf("=== FIN DES TESTS ===\r\n\r\n");
}
