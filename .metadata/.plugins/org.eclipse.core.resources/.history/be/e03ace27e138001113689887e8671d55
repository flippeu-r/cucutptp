/**
 * @file Dht22.c
 * @brief Librairie DHT22 pour STM32L073 avec LL - SYS3046
 *
 * Protocole DHT22 :
 * 1. STM32 envoie signal bas pendant 1ms (start signal)
 * 2. STM32 relache la ligne et passe en entree
 * 3. DHT22 repond avec bas 80us + haut 80us
 * 4. DHT22 envoie 40 bits : bas 50us + haut 26us=0 ou 70us=1
 * 5. Verification du checksum (octet 5 = somme des 4 premiers)
 */

#include "Dht22.h"
#include <stdio.h>

/* Variable SysTick externe (definie dans stm32l0xx_it.c) */
extern volatile uint32_t get_tick;

/* ---- Macros de controle de la broche ---- */
#define PIN_LOW()    LL_GPIO_ResetOutputPin(DHT22_PORT, DHT22_PIN)
#define PIN_HIGH()   LL_GPIO_SetOutputPin(DHT22_PORT, DHT22_PIN)
#define PIN_READ()   LL_GPIO_IsInputPinSet(DHT22_PORT, DHT22_PIN)

/* ---- Delai en millisecondes via SysTick ---- */
static void delayMs(uint32_t ms) {
    uint32_t start = get_tick;
    while ((get_tick - start) < ms);
}

/* ---- Delai en microsecondes via boucle CPU (16MHz) ---- */
/* volatile empeche l'optimisation du compilateur */
void DHT22_DelayUs(uint32_t us) {
    volatile uint32_t count = us * 3;
    while (count--);
}

/* ---- Passe la broche en sortie open-drain ---- */
static void setOutput(void) {
    LL_GPIO_InitTypeDef cfg = {0};
    cfg.Pin        = DHT22_PIN;
    cfg.Mode       = LL_GPIO_MODE_OUTPUT;
    cfg.OutputType = LL_GPIO_OUTPUT_OPENDRAIN;
    cfg.Pull       = LL_GPIO_PULL_UP;
    cfg.Speed      = LL_GPIO_SPEED_FREQ_VERY_HIGH;
    LL_GPIO_Init(DHT22_PORT, &cfg);
}

/* ---- Passe la broche en entree ---- */
static void setInput(void) {
    LL_GPIO_InitTypeDef cfg = {0};
    cfg.Pin  = DHT22_PIN;
    cfg.Mode = LL_GPIO_MODE_INPUT;
    cfg.Pull = LL_GPIO_PULL_UP;
    LL_GPIO_Init(DHT22_PORT, &cfg);
}

/* ---- Initialisation ---- */
void DHT22_Init(void) {
    setOutput();
    PIN_HIGH();
    delayMs(250); /* Attente stabilisation apres power-on */
    printf("[DHT22] Initialise sur PA0\r\n");
}

/* ---- Lecture des donnees ---- */
DHT22_Data DHT22_Read(void) {
    DHT22_Data result = {0.0f, 0.0f, 1};
    uint8_t rawData[5] = {0, 0, 0, 0, 0};
    uint32_t timeout;

    /* === ETAPE 1 : Signal de demarrage === */
    setOutput();
    PIN_LOW();
    delayMs(2);          /* 2ms bas pour reveiller le capteur */
    PIN_HIGH();
    DHT22_DelayUs(30);   /* 30us avant de passer en entree */
    setInput();

    /* === ETAPE 2 : Attente reponse du capteur === */

    /* Attente front descendant */
    timeout = 10000;
    while (PIN_READ()) {
        timeout--;
        if (timeout == 0) {
            printf("[DHT22] ERREUR : pas de reponse (front descendant)\r\n");
            printf("[DHT22] -> Verifiez cable PA0, resistance 10K, alimentation 3.3V\r\n");
            result.error = 1;
            return result;
        }
    }
    printf("[DHT22] Front descendant OK\r\n");

    /* Attente front montant (~80us) */
    timeout = 10000;
    while (!PIN_READ()) {
        timeout--;
        if (timeout == 0) {
            printf("[DHT22] ERREUR : timeout front montant\r\n");
            result.error = 1;
            return result;
        }
    }
    printf("[DHT22] Front montant OK\r\n");

    /* Attente front descendant avant donnees (~80us) */
    timeout = 10000;
    while (PIN_READ()) {
        timeout--;
        if (timeout == 0) {
            printf("[DHT22] ERREUR : timeout avant donnees\r\n");
            result.error = 1;
            return result;
        }
    }
    printf("[DHT22] Capteur pret, lecture 40 bits...\r\n");

    /* === ETAPE 3 : Lecture des 40 bits === */
    for (uint8_t i = 0; i < 40; i++) {
        uint32_t lowTime = 0, highTime = 0;

        /* Attente front montant */
        timeout = 10000;
        while (!PIN_READ()) {
            lowTime++;
            timeout--;
            if (timeout == 0) {
                printf("[DHT22] ERREUR : timeout bit %d (front montant)\r\n", i);
                result.error = 1;
                return result;
            }
        }

        /* Mesure duree etat haut */
        timeout = 10000;
        while (PIN_READ()) {
            highTime++;
            timeout--;
            if (timeout == 0) {
                printf("[DHT22] ERREUR : timeout bit %d (front descendant)\r\n", i);
                result.error = 1;
                return result;
            }
        }

        /* haut > bas => bit '1', sinon bit '0' */
        rawData[i / 8] <<= 1;
        if (highTime > lowTime) {
            rawData[i / 8] |= 1;
        }
    }

    /* === ETAPE 4 : Verification checksum === */
    printf("[DHT22] Donnees : %02X %02X %02X %02X | checksum recu: %02X\r\n",
           rawData[0], rawData[1], rawData[2], rawData[3], rawData[4]);

    uint8_t checksum = rawData[0] + rawData[1] + rawData[2] + rawData[3];
    if (checksum != rawData[4]) {
        printf("[DHT22] ERREUR checksum (calcule: %02X != recu: %02X)\r\n",
               checksum, rawData[4]);
        result.error = 1;
        return result;
    }

    /* === ETAPE 5 : Conversion === */
    result.humidity = (float)(((uint16_t)rawData[0] << 8) | rawData[1]) * 0.1f;
    if (rawData[2] & 0x80) {
        result.temperature = (float)(((uint16_t)(rawData[2] & 0x7F) << 8) | rawData[3]) * -0.1f;
    } else {
        result.temperature = (float)(((uint16_t)rawData[2] << 8) | rawData[3]) * 0.1f;
    }

    result.error = 0;
    printf("[DHT22] OK : Temp=%.1f C  Hum=%.1f %%\r\n",
           result.temperature, result.humidity);

    return result;
}
